<Window x:Class="HCI_2025_Project_Template.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HCI_2025_Project_Template"
        mc:Ignorable="d"
        Title="Paperless_ngx"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen">


    <!-- Viewbox za pravu responzivnost -->
    <Viewbox Stretch="Uniform">
        <Grid Width="800" Height="600">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Logo -->
                <RowDefinition Height="Auto" />
                <!-- Tekst -->
                <RowDefinition Height="Auto" />
                <!-- Username -->
                <RowDefinition Height="Auto" />
                <!-- Password -->
                <RowDefinition Height="Auto" />
                <!-- Dugme -->
                <RowDefinition Height="*" />
                <!-- Prazan prostor -->
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <Image Grid.Row="0"
                   Source="Assets/Paperless-Ngx_Black_Logo.png"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Stretch="Uniform"
                   MaxWidth="350"
                   MaxHeight="200"/>

            <!-- TEKST -->
            <TextBlock Grid.Row="1"
                       Text="Please sign in."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       Margin="0,10,0,10"/>

            <!-- USERNAME -->
            <TextBox Grid.Row="2"
                     x:Name="txtBox_username"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Width="350"
                     Margin="5"
                     materialDesign:HintAssist.Hint="Username"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:TextFieldAssist.HasLeadingIcon="True"
                     materialDesign:TextFieldAssist.LeadingIcon="Account"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontSize="16"
                     TextChanged="txtBox_username_TextChanged"
                     GotFocus="txtBox_username_GotFocus"
                     LostFocus="txtBox_username_LostFocus">
            </TextBox>

            <!-- POPUP -->
            <Popup x:Name="popupSuggestions"
                   PlacementTarget="{Binding ElementName=txtBox_username}"
                   Placement="Top"
                   StaysOpen="False">
                <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                    <ListBox x:Name="listSuggestions"
                             SelectionChanged="listSuggestions_SelectionChanged"
                             MaxHeight="200"
                             FontSize="16" />
                </Border>
            </Popup>

            <!-- PASSWORD -->
            <PasswordBox Grid.Row="3"
                         x:Name="passwordBox_password"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Width="350"
                         materialDesign:HintAssist.Hint="Password"
                         materialDesign:PasswordBoxAssist.Password="{Binding Password1, Mode=TwoWay}"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Key"
                         Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
                         FontSize="16"/>

            <!-- DUGME -->
            <Button Grid.Row="4"
                    x:Name="button_login"
                    Content="Sign in"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="350" Height="40"
                    Margin="0,10,0,0"
                    Background="#0D4D26"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                    IsDefault="True"
                    Click="Button_Click"
                    FontSize="16"/>
        </Grid>
    </Viewbox>
</Window>
