<Window x:Class="HCI_2025_Project_Template.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HCI_2025_Project_Template"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <!-- za logo -->
            <RowDefinition Height="1*"/>
            <!-- za ostalo -->
            <RowDefinition Height="0.10*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Source="Assets/Paperless-Ngx_Black_Logo.png"
           HorizontalAlignment="Center"
           VerticalAlignment="Bottom"
           Grid.Row="0"
           Stretch="Uniform"
           MaxWidth="350"
           MaxHeight="200"/>
        
        <TextBlock 
            Grid.Row="1"
            Text="Please sign in."
            FontSize="15"
            Foreground="Black"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"/>
        
        <TextBox 
            x:Name="txtBox_username" 
            Grid.Row="2"
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch" 
            MaxWidth="350"
            materialDesign:HintAssist.Hint="Username"
            materialDesign:TextFieldAssist.HasClearButton="True"
            materialDesign:TextFieldAssist.HasLeadingIcon="True"
            materialDesign:TextFieldAssist.LeadingIcon="Account"
            Style="{StaticResource MaterialDesignOutlinedTextBox}" 
            FontSize="16"
             TextChanged="txtBox_username_TextChanged"
            GotFocus="txtBox_username_GotFocus"
            LostFocus="txtBox_username_LostFocus"/>

        <Popup x:Name="popupSuggestions"
           PlacementTarget="{Binding ElementName=txtBox_username}"
           Placement="Top"
           StaysOpen="False">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                <ListBox x:Name="listSuggestions"
                     SelectionChanged="listSuggestions_SelectionChanged"
                      MaxHeight="200" 
                      FontSize="16"   
                         />
            </Border>
        </Popup>


        <PasswordBox
            x:Name="passwordBox_password"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" 
            MaxWidth="350"
            materialDesign:HintAssist.Hint="Password"
            materialDesign:PasswordBoxAssist.Password="{Binding Password1, Mode=TwoWay}"
            materialDesign:TextFieldAssist.HasClearButton="True"
            materialDesign:TextFieldAssist.HasLeadingIcon="True"
            materialDesign:TextFieldAssist.LeadingIcon="Key"
            Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}" FontSize="16"/>

        <Button 
            x:Name="button_login" 
            Grid.Row="4"
            Content="Sign in" 
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Margin="0,10,0,0"
            Height="40"
            MaxWidth="350"
            IsDefault="True"
            Background="#0D4D26"
            Style="{StaticResource MaterialDesignFlatDarkBgButton}" 
            Click="Button_Click" FontSize="16"/>
    </Grid>
</Window>
