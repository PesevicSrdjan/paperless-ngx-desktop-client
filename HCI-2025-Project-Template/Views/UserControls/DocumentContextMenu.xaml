<UserControl x:Class="HCI_2025_Project_Template.Views.UserControls.DocumentContextMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Name="root">
    
    <UserControl.Resources>
        
            <!--============= CONTROL SIZES ============-->
            <sys:Double x:Key="IconSize">20</sys:Double>
        
        <ContextMenu x:Key="DocumentContextMenu">
            <MenuItem Header="Open" Click="OpenDocument_Click">
                <MenuItem.Icon>
                    <materialDesign:PackIcon 
                        Kind="FolderOpen" 
                        Width="{StaticResource IconSize}" 
                        Height="{StaticResource IconSize}"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="Download" Click="DownloadDocument_Click">
                <MenuItem.Icon>
                    <materialDesign:PackIcon 
                        Kind="Download" 
                        Width="{StaticResource IconSize}" 
                        Height="{StaticResource IconSize}"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="View Details" Click="ViewDetails_Click">
                <MenuItem.Icon>
                    <materialDesign:PackIcon 
                        Kind="FileDocument" 
                        Width="{StaticResource IconSize}" 
                        Height="{StaticResource IconSize}"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>
</UserControl>