<UserControl x:Class="HCI_2025_Project_Template.Views.UserControls.DocumentsTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.UserControls"
             mc:Ignorable="d"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- ========== COLORS ========== -->
        <SolidColorBrush x:Key="TagsForeground">White</SolidColorBrush>

        <!-- ========== MARGINS ========== -->
        <Thickness x:Key="TableViewGridMargins">20</Thickness>
        <Thickness x:Key="DataGridMargins">0,0,0,10</Thickness>
        <Thickness x:Key="TagsMargins">2</Thickness>

        <!-- ========== BORDER THICKNESS ========== -->
        <Thickness x:Key="CellBorderThickness">0</Thickness>

        <!-- ========== CORNER RADIUS ========== -->
        <CornerRadius x:Key="TagCornerRadius">6</CornerRadius>

        <!-- ========== PADDING ========== -->
        <Thickness x:Key="TagPadding">4,2</Thickness>

        <!-- ========== FONT SIZE ========== -->
        <sys:Double x:Key="TagsFont">10</sys:Double>

    </UserControl.Resources>
    
    <Grid 
        Background="{DynamicResource MaterialDesignPaper}" 
        Margin="{StaticResource TableViewGridMargins}">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
            x:Name="documentsGrid"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            ItemsSource="{Binding Documents}"
            Margin="{StaticResource DataGridMargins}"
            SelectionUnit="FullRow"
            SelectionMode="Single"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            IsReadOnly="True"
            MouseDoubleClick="DocumentsGrid_MouseDoubleClick">

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="BorderThickness" Value="{StaticResource CellBorderThickness}"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding Title}"
                    Header="{Binding Source={StaticResource LStrings}, Path=[Title]}" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding DateOnly}"
                    Header="{Binding Source={StaticResource LStrings}, Path=[Date]}" />

                <DataGridTemplateColumn Header="{Binding Source={StaticResource LStrings}, Path=[Tags]}" Width="2*">
                    
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding Tags}">
                                
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Border 
                                                Background="{Binding Color}" 
                                                CornerRadius="{StaticResource TagCornerRadius}" 
                                                Padding="{StaticResource TagPadding}" 
                                                Margin="{StaticResource TagsMargins}">
                                            
                                                <TextBlock 
                                                    Text="{Binding Name}" 
                                                    Foreground="{StaticResource TagsForeground}" 
                                                    FontSize="{StaticResource TagsFont}"/>
                                            </Border>
                                        
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Type}"
                    Header="{Binding Source={StaticResource LStrings}, Path=[Type]}" />
            </DataGrid.Columns>
     </DataGrid>
    </Grid>
</UserControl>
