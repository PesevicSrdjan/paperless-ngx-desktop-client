<UserControl x:Class="HCI_2025_Project_Template.Views.UserControls.DocumentsCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.UserControls"
             mc:Ignorable="d"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- ========== COLORS ========== -->
        <SolidColorBrush x:Key="ListBoxItemColor">White</SolidColorBrush>
        <SolidColorBrush x:Key="ListBoxColor">Transparent</SolidColorBrush>
        <SolidColorBrush x:Key="ListBoxItemBorderBrush">#DDD</SolidColorBrush>
        <SolidColorBrush x:Key="SeparatorBackground">#DDD</SolidColorBrush>
        <SolidColorBrush x:Key="TypeForeground">#777</SolidColorBrush>
        <SolidColorBrush x:Key="TitleForeground">Black</SolidColorBrush>
        <SolidColorBrush x:Key="TagForeground">#444</SolidColorBrush>
        <SolidColorBrush x:Key="BorderBrushHover">#4C9AFF</SolidColorBrush>
        <SolidColorBrush x:Key="DropShadowHover">#4C9AFF</SolidColorBrush>
        
        <Color x:Key="DropShadowEffectColor">#888</Color>

        <!-- ========== BORDER THICKNESS ========== -->
        <Thickness x:Key="BorderThicknessListBox">0</Thickness>
        <Thickness x:Key="DefaultBorderThickness">1</Thickness>

        <!-- ========== MARGINS ========== -->
        <Thickness x:Key="ListBoxItemMargins">10</Thickness>
        <Thickness x:Key="TitleMargins">8,6,8,0</Thickness>
        <Thickness x:Key="SeparatorMargins">8,2,8,2</Thickness>
        <Thickness x:Key="TypeMargins">8,2,8,4</Thickness>
        <Thickness x:Key="TagsMargins">8,0,8,8</Thickness>
        <Thickness x:Key="TagMargins">2</Thickness>

        <!-- ========== CONTROL SIZES ========== -->
        <sys:Double x:Key="ListBoxItemWidth">160</sys:Double>
        <sys:Double x:Key="ThumbnailImageHeight">180</sys:Double>
        <sys:Double x:Key="SeparatorHeight">1</sys:Double>

        <!-- ========== CORNER RADIUS ========== -->
        <CornerRadius x:Key="ListBoxItemCornerRadius">12</CornerRadius>
        <CornerRadius x:Key="CardCornerRadius">5</CornerRadius>
        <CornerRadius x:Key="ThumbnailCornerRadius">12,12,0,0</CornerRadius>
        <CornerRadius x:Key="TagCornerRadius">6</CornerRadius>

        <!-- ========== FONT SIZE ========== -->
        <sys:Double x:Key="TagFont">10</sys:Double>

        <!-- ========== PADDING ========== -->
        <Thickness x:Key="TagPadding">4,2</Thickness>

    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">

        <ListBox 
            ItemsSource="{Binding Documents}" 
            BorderThickness="{StaticResource BorderThicknessListBox}"
            Background="{StaticResource ListBoxColor}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel 
                        IsItemsHost="True" 
                        Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Margin="{StaticResource ListBoxItemMargins}"
                        Width="{StaticResource ListBoxItemWidth}"
                        CornerRadius="{StaticResource ListBoxItemCornerRadius}"
                        Background="{StaticResource ListBoxItemColor}"
                        BorderBrush="{StaticResource ListBoxItemBorderBrush}"
                        BorderThickness="{StaticResource DefaultBorderThickness}">

                        <Border.Effect>
                            <DropShadowEffect 
                                Color="{StaticResource DropShadowEffectColor}" BlurRadius="8" ShadowDepth="2" Opacity="0.25"/>
                        </Border.Effect>

                        <StackPanel>
                            <!-- Thumbnail -->
                            <Border 
                                CornerRadius="{StaticResource ThumbnailCornerRadius}" 
                                ClipToBounds="True">
                                <Image 
                                    Source="{Binding Thumbnail}"
                                    Height="{StaticResource ThumbnailImageHeight}"
                                    Stretch="UniformToFill"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>

                            <!-- Title -->
                            <TextBlock 
                                Foreground="{StaticResource TitleForeground}"
                                Text="{Binding Title}"
                                FontSize="{StaticResource BodyFontSizeSmall}"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap"
                                Margin="{StaticResource TitleMargins}"/>

                            <Separator 
                                Margin="{StaticResource SeparatorMargins}" 
                                Background="{StaticResource SeparatorBackground}" 
                                Height="{StaticResource SeparatorHeight}"/>

                            <!-- Type -->
                            <TextBlock 
                                Text="{Binding Type}"
                                Foreground="{StaticResource TypeForeground}"
                                FontSize="{StaticResource BodyFontSizeExtraSmall}"
                                Margin="{StaticResource TypeMargins}"/>

                            <!-- Tags -->
                            <ItemsControl 
                                ItemsSource="{Binding Tags}"
                                Margin="{StaticResource TagsMargins}">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border 
                                            Background="{Binding Color}"
                                            CornerRadius="{StaticResource TagCornerRadius}"
                                            Padding="{StaticResource TagPadding}"
                                            Margin="{StaticResource TagMargins}">
                                            <TextBlock 
                                                Text="{Binding Name}" 
                                                FontSize="{StaticResource TagFont}" 
                                                Foreground="{StaticResource TagForeground}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Hover efekat -->
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform 
                                            ScaleX="1" 
                                            ScaleY="1"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushHover}"/>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#4C9AFF" BlurRadius="12" ShadowDepth="2" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
