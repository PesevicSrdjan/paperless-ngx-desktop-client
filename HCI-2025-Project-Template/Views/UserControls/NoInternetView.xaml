<UserControl x:Class="HCI_2025_Project_Template.Views.UserControls.NoInternetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.UserControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

            <!-- ========== TEXT ========== -->
        <sys:String x:Key="NoInternetIcon">📡</sys:String>

            <!-- ========== FONT SIZES ========== -->
        <sys:Double x:Key="NoInternetIconFontSize">48</sys:Double>
        <sys:Double x:Key="NoInternetTitleFontSize">18</sys:Double>
        <sys:Double x:Key="NoInternetDescriptionFontSize">14</sys:Double>

            <!-- ========== MARGINS ========== -->
        <Thickness x:Key="NoInternetDescriptionMargin">20</Thickness>

            <!-- ========== BUTTON SIZES ========== -->
        <sys:Double x:Key="RetryButtonWidth">170</sys:Double>
        <sys:Double x:Key="RetryButtonHeight">35</sys:Double>

    </UserControl.Resources>
    
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{StaticResource NoInternetIcon}"
                       FontSize="{StaticResource NoInternetIconFontSize}"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding Source={StaticResource LStrings}, Path=[NoInternetConnectionText]}"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       FontSize="{StaticResource NoInternetTitleFontSize}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding Source={StaticResource LStrings}, Path=[CheckConnectionText]}"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       FontSize="{StaticResource BodyFontSizeSmall}"
                       Margin="{StaticResource NoInternetDescriptionMargin}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <Button Content="{Binding Source={StaticResource LStrings}, Path=[TryAgain]}"
                    Background="{DynamicResource AccentColor}"
                    Width="{StaticResource RetryButtonWidth}"
                    Height="{StaticResource RetryButtonHeight}"
                    Click="Retry_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
