<UserControl x:Class="HCI_2025_Project_Template.Views.UserControls.DocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.UserControls"
             xmlns:models="clr-namespace:HCI_2025_Project_Template.Core.Models.Ui"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            
            <Setter Property="Height" Value="26"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="20,12,20,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="5,2,5,2"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="#666"/>

            <Setter Property="materialDesign:HintAssist.Hint" Value="Search"/>
            <Setter Property="materialDesign:TextFieldAssist.HasLeadingIcon" Value="True"/>
            <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
            <Setter Property="materialDesign:TextFieldAssist.LeadingIcon" Value="Search"/>

            <Setter Property="IsEnabled" Value="True"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoadingCircularProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="IsIndeterminate" Value="True"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Margin" Value="20,0,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FiltersStyle" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="materialDesign:TextFieldAssist.HasLeadingIcon" Value="True"></Setter>
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"></Setter>
            <Setter Property="Background" Value="White"></Setter>
            <Setter Property="Foreground" Value="#17541F"></Setter>
            <Setter Property="BorderBrush" Value="#17541F"></Setter>
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="FontSize" Value="13"></Setter>
            <Setter Property="Padding" Value="5,2,4,2"></Setter>
            <Setter Property="Grid.Row" Value="2"></Setter>
            <Setter Property="Grid.Column" Value="2"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Right"></Setter>
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>

        </Style>

        <Style x:Key="FilterBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"></Setter>
            <Setter Property="Padding" Value="2"></Setter>
        </Style>

        <Style x:Key="ItemsBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"></Setter>
            <Setter Property="Padding" Value="4,2"></Setter>
            <Setter Property="Margin" Value="2"></Setter>
        </Style>

        <Style x:Key="CheckBoxFilter" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="Margin" Value="0,0,4,0"></Setter>
        </Style>

        <Style x:Key="PaginationPageStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="IsEnabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <Grid Background="White">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/> 
        </Grid.ColumnDefinitions>

        <TextBlock 
           Text="Documents" 
           FontSize="30"
           HorizontalAlignment="Left"
           Margin="20,20,0,0"
           FontWeight="SemiBold"/>

        <StackPanel
            Grid.Row="0"
            Grid.Column="2"
            Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            Margin="0,20,20,0">

            <Button 
                Style="{StaticResource MaterialDesignToolButton}"
                ToolTip="Card View"
                Margin="0,0,10,0"
                Click="cardView_Click">

                <materialDesign:PackIcon 
                    Kind="ViewModule" 
                    Width="24" 
                    Height="24"
                    Foreground="#17541F"/>
            </Button>
            
            <Button 
                Style="{StaticResource MaterialDesignToolButton}"
                ToolTip="Table View"
                Click="tableView_Click">

                <materialDesign:PackIcon 
                    Kind="ViewList" 
                    Width="24" 
                    Height="24"
                    Foreground="#17541F"/>
            </Button>
        </StackPanel>

        <TextBox
            Grid.Row="1"
            Grid.ColumnSpan="3"
            x:Name="textBox_search"
            Style="{StaticResource SearchTextBoxStyle}"/>

        <!--Ostavljen prostor za filtere-->
        <ComboBox
            x:Name="ComboBoxTags"
            Style="{StaticResource FiltersStyle}"
            materialDesign:HintAssist.Hint="Tags"
            materialDesign:TextFieldAssist.LeadingIcon="Tag"
            Margin="0,5,315,10"
            ItemsSource="{Binding TagsList}"
            SelectionChanged="ComboBoxTags_SelectionChanged">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Style="{StaticResource FilterBorderStyle}"
                        MouseLeftButtonDown="Item_Click"
                        PreviewMouseLeftButtonDown="Item_Click">
                        
                        <StackPanel 
                            Orientation="Horizontal">
                            <CheckBox 
                                Style="{StaticResource CheckBoxFilter}"
                                Checked="CheckBox_Checked_Tag"
                                Unchecked="CheckBox_Unchecked_Tag"/>
                            <Border 
                                Style="{StaticResource ItemsBorderStyle}"
                                Background="{Binding Color}">
                            <TextBlock 
                                Text="{Binding Name}" 
                                Foreground="White" 
                                FontSize="10"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <ComboBox
            x:Name="ComboBoxCorrespondents"
            Style="{StaticResource FiltersStyle}"
            materialDesign:HintAssist.Hint="Correspondent"
            materialDesign:TextFieldAssist.LeadingIcon="Account"
            ItemsSource="{Binding CorrespondentsList}"
            SelectionChanged="ComboBoxCorrespondents_SelectionChanged"
            Width="140"
            Margin="0,5,170,10">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Style="{StaticResource FilterBorderStyle}"
                        MouseLeftButtonDown="Item_Click"
                        PreviewMouseLeftButtonDown="Item_Click">
                        
                        <StackPanel Orientation="Horizontal">
                            <CheckBox 
                                Style="{StaticResource CheckBoxFilter}"
                                Checked="CheckBox_Checked_Corr"
                                Unchecked="CheckBox_Unchecked_Corr"/>
                            <Border 
                                Style="{StaticResource ItemsBorderStyle}"
                                Background="{Binding Color}">
                                <TextBlock 
                                    Text="{Binding Name}" 
                                    Foreground="Black" 
                                    FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <ComboBox
             x:Name="ComboBoxTypes"
             Style="{StaticResource FiltersStyle}"
             materialDesign:HintAssist.Hint="Document Type"
             materialDesign:TextFieldAssist.LeadingIcon="FileDocument"
             Width="145"
             Margin="0,5,20,10"
             ItemsSource="{Binding TypesList}"
             SelectionChanged="ComboBoxTypes_SelectionChanged">

            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Style="{StaticResource FilterBorderStyle}"
                        MouseLeftButtonDown="Item_Click"
                        PreviewMouseLeftButtonDown="Item_Click">
                        <StackPanel 
                            Orientation="Horizontal">
                            <CheckBox 
                                Style="{StaticResource CheckBoxFilter}"
                                Checked="CheckBox_Checked_Type"
                                Unchecked="CheckBox_Unchecked_Type"/>
                            <Border 
                                Style="{StaticResource ItemsBorderStyle}">
                                <TextBlock 
                                    Text="{Binding Name}" 
                                    Foreground="Black" 
                                    FontSize="12"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="20,40,20,10" VerticalAlignment="Top" HorizontalAlignment="Left">
            <!-- ItemsControl za aktivne filtere -->
            <ItemsControl ItemsSource="{Binding ActiveFilters}">
                <ItemsControl.Resources>
                    <DataTemplate 
                        DataType="{x:Type models:TagInfo}">
                        <Border 
                            Background="{Binding Color}" CornerRadius="6" Padding="4,2" Margin="2">
                            <TextBlock 
                                Text="{Binding Name}" 
                                Foreground="White" 
                                FontSize="10"/>
                        </Border>
                    </DataTemplate>
                    <DataTemplate 
                        DataType="{x:Type models:DocTypeInfo}">
                        <Border 
                            Background="LightGray" CornerRadius="6" Padding="4,2" Margin="2">
                            <TextBlock 
                                Text="{Binding Name}" 
                                Foreground="Black" 
                                FontSize="12"/>
                        </Border>
                    </DataTemplate>

                    <DataTemplate 
                        DataType="{x:Type models:CorrespondentsInfo}">
                        <Border 
                            Background="LightGray" CornerRadius="6" Padding="4,2" Margin="2">
                            <TextBlock 
                                Text="{Binding Name}" 
                                Foreground="Black" 
                                FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.Resources>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </WrapPanel>

        <!-- Clear Filters dugme -->
        <Button
            Grid.Row="3"
            Grid.Column="1"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Content="Clear Filters"
            Padding="5,2"
            Click="ClearFilters_Click">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                    <Setter Property="Visibility" Value="Visible"/>
                    
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        
                        <DataTrigger Binding="{Binding HasActiveFilters}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <StackPanel Grid.Row="3" Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">

            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <!-- ProgressBar za učitavanje -->
                <ProgressBar 
                    x:Name="loadingBar"
                    Style="{StaticResource LoadingCircularProgressBar}">
                </ProgressBar>

                <TextBlock
                    Text="Loading..."
                    FontStyle="Italic"
                    Foreground="Gray"
                    Margin="10,10,0,0">
                    
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- TextBlock sa brojem dokumenata -->
            <TextBlock 
                FontWeight="SemiBold"
                FontSize="14"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                Text="{Binding DocumentCountDisplay}">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <StackPanel 
            Orientation="Horizontal" 
            HorizontalAlignment="Right"
            Grid.Row="3" 
            Grid.Column="2">

            <Button 
                Style="{StaticResource PaginationPageStyle}" 
                Padding="2" Margin="0,0,0,0"
                Width="28" Height="28"
                Click="PreviousPage_Click">

                <materialDesign:PackIcon 
                    Kind="ChevronDoubleLeft" 
                    Width="25" 
                    Height="25"/>
            </Button>

            <Button 
                Style="{StaticResource MaterialDesignFlatDarkBgButton}" 
                Padding="0"
                Width="30" 
                Height="30"
                Foreground="Black"
                Background="White">

                <TextBlock Text="{Binding CurrentPage}"
                    Foreground="Black"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Button>

            <Button 
                Style="{StaticResource PaginationPageStyle}"
                Padding="2"
                Margin="0,0,20,0"
                Width="28" Height="28"
                Click="NextPage_Click">

                <materialDesign:PackIcon 
                    Kind="ChevronDoubleRight" 
                    Width="25" 
                    Height="25"/>
            </Button>
        </StackPanel>
        <ContentControl x:Name="DocumentContentControl" Grid.Row="4" Grid.ColumnSpan="3"></ContentControl>
    </Grid>
</UserControl>
