<Window x:Class="HCI_2025_Project_Template.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HCI_2025_Project_Template.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="DashboardWindow"
        d:Height="1020" 
        d:Width="1920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Icon="/Assets/paperless.ico">
        <!--'d:Height="1020"' && d:Width="1919" postavljeno zbog design-a-->

    <Window.Resources>

        <SolidColorBrush x:Key="SideBarIconForeground">White</SolidColorBrush>
        <SolidColorBrush x:Key="SideBarTextForeground">#666</SolidColorBrush>
        <SolidColorBrush x:Key="PaperlessTextForeground">White</SolidColorBrush>
        <Color x:Key="DropShadowColor">Black</Color>

        <!-- ========== CONTROL SIZES ========== -->
        <sys:Double x:Key="SideBarIconWidth">20</sys:Double>
        <sys:Double x:Key="SideBarIconHeight">20</sys:Double>
        <sys:Double x:Key="BorderHeight">50</sys:Double>
        <sys:Double x:Key="ImageWidth">30</sys:Double>
        <sys:Double x:Key="ImageHeight">30</sys:Double>
        <sys:Double x:Key="PaperlessTextWidth">130</sys:Double>

        <!-- ========== PADDING ========== -->
        <Thickness x:Key="SideBarButtonPadding">10,8</Thickness>

        <!-- ========== MARGINS ========== -->
        <Thickness x:Key="SideBarButtonMargin">0,5</Thickness>
        <Thickness x:Key="SideBarIconMargin">20,0,8,0</Thickness>
        <Thickness x:Key="SideBarTextMargin">20,20,0,10</Thickness>
        <Thickness x:Key="ImageMargin">10,10,0,0</Thickness>
        <Thickness x:Key="PaperlessTextMargin">0,15,0,0</Thickness>

        <!-- ========== FONT SIZE ========== -->
        <sys:Double x:Key="PaperlessTextFont">15</sys:Double>

        <!-- ========== BORDER THICKNESS ========== -->
        <Thickness x:Key="PaperlessBorderThickness">0,0,1,0</Thickness>

        <!-- Style za sve Buttone na Sidebar (Navigation bar)-->
        <Style x:Key="SideBarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Padding" Value="{StaticResource SideBarButtonPadding}"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"></Setter>
            <Setter Property="Margin" Value="{StaticResource SideBarButtonMargin}"></Setter>
            <EventSetter Event="Click" Handler="SidebarButton_Click"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon 
                                Kind="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}"
                                Width="{StaticResource SideBarIconWidth}"
                                Height="{StaticResource SideBarIconHeight}" 
                                VerticalAlignment="Center"
                                Margin="{StaticResource SideBarIconMargin}"
                                Foreground="{StaticResource SideBarIconForeground}">
                                <materialDesign:PackIcon.Effect>
                                    <DropShadowEffect Color="{StaticResource DropShadowColor}" ShadowDepth="0" BlurRadius="6"/>
                                </materialDesign:PackIcon.Effect>
                            </materialDesign:PackIcon>

                            <TextBlock x:Name="ButtonText"
                               Text="{Binding Content, RelativeSource={RelativeSource AncestorType=Button}}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource BodyFontSizeSmall}"
                               Foreground="{TemplateBinding Foreground}"
                               FontWeight="{TemplateBinding FontWeight}"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonText" Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="ButtonText" Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            
        </Style>
        
        <!--Style za sve TextBlock na Sidebar (Navigation bar)-->
        <Style x:Key="SideBarTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource BodyFontSizeExtraSmall}"></Setter>
            <Setter Property="FontWeight" Value="SemiBold"></Setter>
            <Setter Property="Foreground" Value="{StaticResource SideBarTextForeground}"></Setter>
            <Setter Property="Margin" Value="{StaticResource SideBarTextMargin}"></Setter>
            <Setter Property="HorizontalAlignment" Value="Left"></Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Ikona -->
            <ColumnDefinition Width="Auto"/>
            <!-- Tekst -->
            <ColumnDefinition Width="Auto"/>
            <!-- Search box -->
            <ColumnDefinition Width="*"/>
            <!-- Ostatak -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="4"
            VerticalAlignment="Top"
            Background="{DynamicResource AccentColor}"
            Height="{StaticResource BorderHeight}"/>
        
        <Image Grid.Row="0" Grid.Column="0"
            Source="/Assets/paperless-flower.png"
            Stretch="Uniform"
            VerticalAlignment="Top"
            HorizontalAlignment="Center"
            Margin="{StaticResource ImageMargin}"
            Width="{StaticResource ImageWidth}"
            Height="{StaticResource ImageHeight}"/>

        <TextBlock Grid.Row="0" Grid.Column="1"
            Text="Paperless-ngx"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Margin="{StaticResource PaperlessTextMargin}"
            Width="{StaticResource PaperlessTextWidth}"
            Foreground="{StaticResource PaperlessTextForeground}"
            FontFamily="Segoe UI"
            FontSize="{StaticResource PaperlessTextFont}"
            TextOptions.TextRenderingMode="ClearType"
            TextOptions.TextFormattingMode="Ideal"/>
        
        <Border Grid.Row="1" Grid.ColumnSpan="2" 
            Background="{DynamicResource MaterialDesignPaper}" 
            BorderBrush="{DynamicResource MaterialDesignBody}" 
            BorderThickness="{StaticResource PaperlessBorderThickness}">

            <StackPanel>
                <Button
                    x:Name="button_dashboard"
                    Style="{StaticResource SideBarButtonStyle}"
                    Tag="Home"
                    Content="Dashboard"
                    Click="button_dashboard_Click">
                </Button>

                <Button
                    x:Name="button_documents"
                    Style="{StaticResource SideBarButtonStyle}"
                    Tag="DriveDocument"
                    Content="Documents"
                    Click="button_documents_Click">
                </Button>

                <TextBlock
                    Text="MANAGE"
                    Style="{StaticResource SideBarTextBlock}">
                </TextBlock>

                <Button
                    x:Name="button_correspondents"
                    Style="{StaticResource SideBarButtonStyle}"
                    Tag="Account"
                    Content="Correspondents">
                </Button>

                <Button
                    x:Name="button_tags"
                    Style="{StaticResource SideBarButtonStyle}"
                    Tag="Tags"
                    Content="Tags"
                    Click="button_tags_Click">
                </Button>

                <Button
                    x:Name="Button_Settings"
                    Style="{StaticResource SideBarButtonStyle}"
                    Tag="Settings"
                    Content="Settings"
                    Click="Button_Settings_Click">
                </Button>
                
            </StackPanel>
        </Border>

        <ContentControl x:Name="MainContentControl" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"></ContentControl>
    </Grid>
</Window>
