<UserControl x:Class="HCI_2025_Project_Template.Views.Dialogs.DeleteDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.Dialogs"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- ========== FONT SIZES ========== -->
        <sys:Double x:Key="DeleteTagTitleFontSize">18</sys:Double>

        <!-- ========== COLORS ========== -->
        <SolidColorBrush x:Key="DeleteTagDescriptionForeground">#6B7280</SolidColorBrush>
        <SolidColorBrush x:Key="DeleteTagConfirmButtonBackground">#EF4444</SolidColorBrush>

        <!-- ========== MARGINS ========== -->
        <Thickness x:Key="DeleteTagMainMargin">24</Thickness>
        <Thickness x:Key="DeleteTagTitleMargin">0,0,0,8</Thickness>
        <Thickness x:Key="DeleteTagDescriptionMargin">0,0,0,20</Thickness>
        <Thickness x:Key="DeleteTagCancelButtonMargin">0,0,8,0</Thickness>

    </UserControl.Resources>

    <StackPanel Margin="{StaticResource DeleteTagMainMargin}">
        <TextBlock 
            Text="{Binding DeleteTitle}" 
            FontSize="{StaticResource DeleteTagTitleFontSize}" 
            FontWeight="SemiBold" 
            Margin="{StaticResource DeleteTagTitleMargin}"/>

        <TextBlock 
            Text="{Binding DeleteSubtitle}"
            TextWrapping="Wrap" 
            Foreground="{StaticResource DeleteTagDescriptionForeground}" 
            Margin="{StaticResource DeleteTagDescriptionMargin}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button
                Content="{Binding Source={StaticResource LStrings}, Path=[Cancel]}"
                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                Margin="{StaticResource DeleteTagCancelButtonMargin}">
            </Button>
            <Button 
                Content="{Binding Source={StaticResource LStrings}, Path=[DeleteTagButton]}"
                Background="{StaticResource DeleteTagConfirmButtonBackground}"
                Click="Delete_Click">
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
