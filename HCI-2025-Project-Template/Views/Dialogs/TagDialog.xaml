<UserControl x:Class="HCI_2025_Project_Template.Views.Dialogs.TagDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCI_2025_Project_Template.Views.Dialogs"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">


    <UserControl.Resources>

        <!-- ========== SIZES ========== -->
        <sys:Double x:Key="TagDialogWidth">500</sys:Double>
        <sys:Double x:Key="TagDialogTitleFontSize">18</sys:Double>

        <!-- ========== MARGINS ========== -->
        <Thickness x:Key="TagDialogMainMargin">24</Thickness>
        <Thickness x:Key="TagDialogTitleMargin">0,0,0,16</Thickness>
        <Thickness x:Key="TagDialogTextBoxMargin">0,0,0,12</Thickness>
        <Thickness x:Key="TagDialogColorPickerMargin">0,0,0,8</Thickness>
        <Thickness x:Key="TagDialogHexMargin">0,0,0,20</Thickness>
        <Thickness x:Key="TagDialogCancelButtonMargin">0,0,8,0</Thickness>

    </UserControl.Resources>
    
    <StackPanel Width="{StaticResource TagDialogWidth}" Margin="{StaticResource TagDialogMainMargin}">
        <TextBlock
            Text="{Binding Title}"
            FontSize="{StaticResource TagDialogTitleFontSize}"
            FontWeight="SemiBold"
            Margin="{StaticResource TagDialogTitleMargin}"/>

        <TextBox
            Text="{Binding Name}"
            materialDesign:HintAssist.Hint="Name"
            Margin="{StaticResource TagDialogTextBoxMargin}"/>

        <materialDesign:ColorPicker
            Color="{Binding SelectedColor, Mode=TwoWay ,UpdateSourceTrigger=PropertyChanged}"
            Margin="{StaticResource TagDialogColorPickerMargin}"/>

        <TextBox
            Text="{Binding ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            materialDesign:HintAssist.Hint="HEX color"
            CharacterCasing="Upper"
            Margin="{StaticResource TagDialogHexMargin}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button
                Content="Cancel"
                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                Margin="{StaticResource TagDialogCancelButtonMargin}">
            </Button>

            <Button
                Content="Save"
                IsDefault="True" 
                Click="SaveEdit_Click">
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
